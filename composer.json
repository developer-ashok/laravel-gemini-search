{
    "name": "coderubix/laravel-gemini-search",
    "description": "AI-powered natural language database search using Google Gemini in Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "gemini", "ai", "search", "database", "natural-language"],
    "authors": [
        {
            "name": "Coderubix",
            "email": "info@coderubix.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Coderubix\\GeminiSearch\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "google-gemini-php/laravel": "^1.0",
        "doctrine/dbal": "^3.9|^3.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^9.0",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.13"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Coderubix\\GeminiSearch\\GeminiSearchServiceProvider"
            ],
            "aliases": {
                "GeminiSearch": "Coderubix\\GeminiSearch\\Facades\\GeminiSearch"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyse": "phpstan analyse",
        "format": "pint",
        "check-style": "pint --test"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}